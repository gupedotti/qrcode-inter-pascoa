{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/qrcodes/(.*)", "dest": "/public/qrcodes/$1" },
    { "src": "/(.*\\.(html|css|js|png|jpg|ico|webp|svg))", "dest": "/public/$1" },
    { "src": "/(.*)", "dest": "/server.js" }
  ]
}
